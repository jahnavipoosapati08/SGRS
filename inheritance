class Record:
    def __init__(self, gid):
        self.id = gid

class Grievance(Record):
    def __init__(self, gid, name, category):
        super().__init__(gid)
        self.name = name
        self.category = category

    def show(self):
        print(self.id, self.name, self.category)

g = Grievance(1, "Rahul", "Hostel")
g.show()
